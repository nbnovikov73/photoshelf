DOMAIN=photos.example.com
LETSENCRYPT_EMAIL=admin@example.com

DATABASE_URL=postgresql://photoshelf:replace-postgres-password@postgres:5432/photoshelf?schema=public
POSTGRES_USER=photoshelf
POSTGRES_PASSWORD=replace-postgres-password
POSTGRES_DB=photoshelf

SESSION_SECRET=replace-with-a-long-random-secret
ADMIN_EMAIL=admin@example.com
ADMIN_INITIAL_PASSWORD=replace-with-a-long-random-password
ADMIN_PASSWORD_HASH=

S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=photoshelf
S3_ACCESS_KEY_ID=replace-minio-user
S3_SECRET_ACCESS_KEY=replace-minio-password
S3_PUBLIC_BASE_URL=https://photos.example.com/media/photoshelf
MINIO_ROOT_USER=replace-minio-user
MINIO_ROOT_PASSWORD=replace-minio-password

MAX_UPLOAD_MB=30
