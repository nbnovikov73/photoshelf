---
import { PHOTO_STATUS } from "@photoshelf/shared";
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { listAdminPhotos } from "../../../lib/photo-repository";

const photos = await listAdminPhotos();
---

<AdminLayout title="Photos">
  <a slot="action" class="button button--accent" href="/admin/photos/new">Upload photo</a>

  <section class="admin-panel">
    <div class="admin-list">
      {
        photos.map((photo) => (
          <a class="admin-list-item admin-list-item--photo" href={`/admin/photos/${photo.id}`}>
            <img
              alt={photo.title}
              class="admin-thumb"
              loading="lazy"
              src={photo.thumbnailUrl}
            />
            <div>
              <h3>{photo.title}</h3>
              <p>{photo.description}</p>
            </div>
            <span
              class={
                photo.status === PHOTO_STATUS.published
                  ? "status-pill status-pill--published"
                  : "status-pill"
              }
            >
              {photo.status === PHOTO_STATUS.published ? "Published" : "Draft"}
            </span>
          </a>
        ))
      }
      {photos.length === 0 && <p class="muted">No photographs yet. Upload the first one.</p>}
    </div>
  </section>
</AdminLayout>
